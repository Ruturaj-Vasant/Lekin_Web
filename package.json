{
  "name": "lekin-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "build:pages": "GITHUB_PAGES=true GITHUB_REPOSITORY=Ruturaj-Vasant/Lekin_Web NEXT_PUBLIC_BASE_PATH=/Lekin_Web vinext build && tsx scripts/pages/prepare-static-export.ts",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run lint && npm run build",
    "test:unit": "vitest run",
    "test:types": "tsc --noEmit -p tsconfig.lib.json",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "fixture:generate": "tsx scripts/fixtures/generate-real-execution-fixture.ts",
    "fixture:check": "tsx scripts/fixtures/generate-real-execution-fixture.ts --check",
    "benchmark:browser": "playwright test --config playwright.benchmark.config.ts",
    "example:large": "tsx scripts/benchmarks/generate-large-problem.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@uiw/react-codemirror": "^4.25.11",
    "next": "16.2.6",
    "pyodide": "314.0.2",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "vitest": "^4.1.10",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
